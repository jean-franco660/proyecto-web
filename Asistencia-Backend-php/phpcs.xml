<?xml version="1.0"?>
<ruleset name="AsistenciaRules">
    <description>Reglas de codificación para el Sistema de Asistencia (PSR-12).</description>
    <rule ref="PSR12">
        <exclude name="Generic.Files.LineEndings.InvalidEOLChar"/>
    </rule>
    <file>app</file>
    <file>public</file>
    <file>routes</file>
    <exclude-pattern>*/vendor/*</exclude-pattern>
    <arg name="colors"/>
    <arg value="p"/>
    <arg name="warning-severity" value="0"/>
</ruleset>
