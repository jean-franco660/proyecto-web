{
    "name": "asistencia/backend-php",
    "description": "Backend API PHP MVC para sistema de asistencia",
    "type": "project",
    "require": {
        "php": ">=8.0",
        "firebase/php-jwt": "^7.0",
        "phpmailer/phpmailer": "^7.0",
        "phpoffice/phpspreadsheet": "^5.8"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "config": {
        "optimize-autoloader": true
    },
    "require-dev": {
        "squizlabs/php_codesniffer": "^4.0",
        "phpunit/phpunit": "^10.5"
    }
}
